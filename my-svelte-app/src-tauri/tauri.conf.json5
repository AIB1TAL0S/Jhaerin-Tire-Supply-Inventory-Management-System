// JTS-IMS Tauri configuration
// Rename to tauri.conf.json before building
{
  productName: "JTS-IMS",
  version: "0.1.0",
  identifier: "com.jhaerin.jts-ims",
  build: {
    frontendDist: "../build",
    devUrl: "http://localhost:5173",
    beforeDevCommand: "npm run dev",
    beforeBuildCommand: "npm run build"
  },
  app: {
    windows: [
      {
        title: "Jhaerin Tire Supply IMS",
        width: 1280,
        height: 800,
        minWidth: 900,
        minHeight: 600,
        resizable: true,
        fullscreen: false
      }
    ],
    security: { csp: null },
    trayIcon: {
      iconPath: "icons/icon.png",
      iconAsTemplate: true,
      menuOnLeftClick: false,
      title: "JTS-IMS"
    }
  },
  bundle: {
    active: true,
    targets: "all",
    icon: [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  plugins: {
    sql: {
      preloadConnections: [{ path: "jts-ims.db", readonly: false }]
    },
    notification: {}
  }
}
